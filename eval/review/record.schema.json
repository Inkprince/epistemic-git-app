{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-git.local/schemas/expert-review-records-1.0.json",
  "title": "Expert review records",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "reviews"],
  "properties": {
    "schemaVersion": { "const": "expert-review-records/1.0" },
    "status": { "enum": ["pending-human-review", "in-progress", "complete"] },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "packetId", "status", "artifactBundleId", "artifactSha256", "startedAt", "completedAt", "reviewer", "judgments", "missingEvidence", "overallAssessment", "administratorNotes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "packetId": { "type": "string", "minLength": 1 },
          "status": { "const": "completed" },
          "artifactBundleId": { "type": "string", "pattern": "^bnd_[0-9a-f]{16}$" },
          "artifactSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "startedAt": { "type": "string", "format": "date-time" },
          "completedAt": { "type": "string", "format": "date-time" },
          "reviewer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["publicLabel", "qualification", "declaredStance", "conflicts", "consentToPublishRedactedRecord"],
            "properties": {
              "publicLabel": { "type": "string", "minLength": 1 },
              "qualification": { "type": "string", "minLength": 1 },
              "declaredStance": { "type": "string", "minLength": 1 },
              "conflicts": { "type": "array", "items": { "type": "string" } },
              "consentToPublishRedactedRecord": { "type": "boolean" }
            }
          },
          "judgments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["targetId", "verdict", "severity", "rationale", "sourceOrPassage", "proposedRemedy"],
              "properties": {
                "targetId": { "type": "string", "minLength": 1 },
                "verdict": { "enum": ["accept", "revise", "reject", "uncertain"] },
                "severity": { "enum": ["minor", "major", "critical"] },
                "rationale": { "type": "string", "minLength": 1 },
                "sourceOrPassage": { "type": ["string", "null"] },
                "proposedRemedy": { "type": ["string", "null"] }
              }
            }
          },
          "missingEvidence": { "type": "array", "items": { "type": "string" } },
          "overallAssessment": { "type": "string", "minLength": 1 },
          "administratorNotes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
