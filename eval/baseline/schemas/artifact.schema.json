{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "baseline-artifact/1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "title", "summary", "claims", "citations", "analysis"],
  "properties": {
    "schemaVersion": { "const": "baseline-artifact/1.0" },
    "taskId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "citationIds", "caveats"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "text": { "type": "string", "minLength": 1 },
          "citationIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "caveats": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourceTitle", "sourceUri", "locator", "passage"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "sourceTitle": { "type": "string", "minLength": 1 },
          "sourceUri": { "type": ["string", "null"] },
          "locator": { "type": ["string", "null"] },
          "passage": { "type": ["string", "null"] }
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strongestEvidence", "loadBearingAssumption", "citationIndependence", "passageSupport", "perspectiveDisagreement", "conflictingSourceUpdate", "sourceOverclaim"],
      "properties": {
        "strongestEvidence": { "type": ["string", "null"] },
        "loadBearingAssumption": { "type": ["string", "null"] },
        "citationIndependence": { "type": ["string", "null"] },
        "passageSupport": { "type": ["string", "null"] },
        "perspectiveDisagreement": { "type": ["string", "null"] },
        "conflictingSourceUpdate": { "type": ["string", "null"] },
        "sourceOverclaim": { "type": ["string", "null"] }
      }
    }
  }
}
