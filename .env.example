# Cerebras Inference — required ONLY for `--live` pipeline runs.
# Cached mode (the default) replays the committed cache and needs no key.
CEREBRAS_API_KEY=

# Optional overrides (defaults shown):
# CEREBRAS_MODEL=gpt-oss-120b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_MAX_RETRIES=5          # retries on 429 / 5xx before giving up
# CEREBRAS_RETRY_DELAY_MS=12000   # base backoff (jittered) between retries
# CEREBRAS_TIMEOUT_MS=120000      # per-request timeout; a hung socket aborts instead of blocking
