# LLM provider, required ONLY for `--live` pipeline runs (building a NEW case from source text).
# Cached mode (the default) replays the committed cache and needs no key.
# Provider-agnostic and OpenAI-compatible; defaults target Cerebras gpt-oss-120b.
LLM_API_KEY=

# Optional overrides (defaults shown):
# LLM_BASE_URL=https://api.cerebras.ai/v1   # any OpenAI-compatible endpoint
# LLM_MODEL=gpt-oss-120b                    # routing id sent to the provider (Groq: openai/gpt-oss-120b)
#                                           # (the cache/attribution label stays gpt-oss-120b regardless)
# LLM_MAX_TOKENS=8192          # completion-token ceiling; raise on higher-limit tiers
# LLM_MAX_RETRIES=5            # retries on 429 / 5xx before giving up
# LLM_RETRY_DELAY_MS=12000     # base backoff (jittered) between retries
# LLM_TIMEOUT_MS=120000        # per-request timeout; a hung socket aborts instead of blocking
#
# To use Groq instead of Cerebras:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=openai/gpt-oss-120b
# Legacy CEREBRAS_API_KEY / GROQ_API_KEY names are still accepted for the key.

# Firecrawl, OPTIONAL. Only used for `--scraper firecrawl` (renders JS pages / cleans messy HTML to
# markdown) and `egit discover` (proposes candidate sources). Native fetch is the default and needs no
# key; cached scrape/discovery results replay with no key or network.
FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev
