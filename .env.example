# Groq, required ONLY for `--live` pipeline runs.
# Cached mode (the default) replays the committed cache and needs no key.
GROQ_API_KEY=

# Optional overrides (defaults shown):
# GROQ_MODEL=openai/gpt-oss-120b            # model id sent to Groq (the cache/attribution label stays gpt-oss-120b)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MAX_RETRIES=5          # retries on 429 / 5xx before giving up
# GROQ_RETRY_DELAY_MS=12000   # base backoff (jittered) between retries
# GROQ_TIMEOUT_MS=120000      # per-request timeout; a hung socket aborts instead of blocking

# Firecrawl, OPTIONAL. Only used for `--scraper firecrawl` (renders JS pages / cleans messy HTML to
# markdown) and `egit discover` (proposes candidate sources). Native fetch is the default and needs no
# key; cached scrape/discovery results replay with no key or network.
FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev
